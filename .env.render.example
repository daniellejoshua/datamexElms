APP_NAME=Datamex_ELMS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-render-domain.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DATABASE_URL=mysql://your_username:your_password@aws.connect.psdb.cloud:3306/your_database?sslmode=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=public

BROADCAST_CONNECTION=log
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@datamex-elms.local
MAIL_FROM_NAME="Datamex ELMS"

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Optional when you later add object storage (S3-compatible)
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=
# AWS_ENDPOINT=
# AWS_URL=
# AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
