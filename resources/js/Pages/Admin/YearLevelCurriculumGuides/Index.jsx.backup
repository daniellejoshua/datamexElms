import { Head, Link, router, usePage } from '@inertiajs/react'
import AuthenticatedLayout from '@/Layouts/AuthenticatedLayout'
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card'
import { Badge } from '@/components/ui/badge'
import { Button } from '@/components/ui/button'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'
import { Input } from '@/components/ui/input'
import { Label } from '@/components/ui/label'
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle } from '@/components/ui/dialog'
import { GraduationCap, BookOpen, Plus, Edit, Trash2, Filter, Search, Eye, Star, CheckCircle2 } from 'lucide-react'
import { useState, useEffect } from 'react'
import { toast } from 'sonner'

export default function Index({ guides, programs, currentAcademicYear, filters }) {
    const { flash } = usePage().props;
    const [localFilters, setLocalFilters] = useState(filters || {})
    const [selectedProgram, setSelectedProgram] = useState(null)
    const [isModalOpen, setIsModalOpen] = useState(false)

    const handleFilterChange = (key, value) => {
        const newFilters = { ...localFilters, [key]: value }
        setLocalFilters(newFilters)
        router.get(route('admin.year-level-curriculum-guides.index'), newFilters, {
            preserveState: true,
            replace: true,
        })
    }

    const getYearLevelLabel = (program, yearLevel) => {
        if (program.education_level === 'college') {
            const labels = ['1st Year', '2nd Year', '3rd Year', '4th Year', '5th Year']
            return labels[yearLevel - 1] || `Year ${yearLevel}`
        } else {
            // For senior high: 2-year programs are Grade 11-12, 4-year programs show as Year 1-4
            if (program.total_years === 2) {
                return `Grade ${yearLevel + 10}` // Grade 11, 12
            } else {
                // For 4-year SHS programs (TVL tracks), just show year level
                const labels = ['1st Year', '2nd Year', '3rd Year', '4th Year']
                return labels[yearLevel - 1] || `Year ${yearLevel}`
            }
        }
    }

    const openProgramModal = (program) => {
        setSelectedProgram(program)
        setIsModalOpen(true)
    }

    // Group guides by curriculum to show which year levels use each curriculum
    const groupedByProgram = programs.map(program => {
        const programGuides = guides[program.id] || {}
        const yearLevels = Object.keys(programGuides).sort((a, b) => parseInt(a) - parseInt(b))

        // Group by curriculum
        const curriculumGroups = {}
        yearLevels.forEach(yearLevel => {
            const guide = programGuides[yearLevel][0]
            if (guide && guide.curriculum) {
                const currId = guide.curriculum.id
                if (!curriculumGroups[currId]) {
                    curriculumGroups[currId] = {
                        curriculum: guide.curriculum,
                        yearLevels: [],
                        isCurrent: guide.curriculum.id === program.current_curriculum?.id
                    }
                }
                curriculumGroups[currId].yearLevels.push(parseInt(yearLevel))
            }
        })

        // Convert to array and sort - current curriculum first
        const curriculumArray = Object.values(curriculumGroups).sort((a, b) => {
            if (a.isCurrent && !b.isCurrent) return -1
            if (!a.isCurrent && b.isCurrent) return 1
            return 0
        })

        return {
            program,
            curriculumGroups: curriculumArray,
            hasGuides: curriculumArray.length > 0
        }
    }).filter(group => group.hasGuides)

    const groupedGuides = programs.map(program => {
        const programGuides = guides[program.id] || {}
        const yearLevels = Object.keys(programGuides).sort((a, b) => parseInt(a) - parseInt(b))

        return {
            program,
            guides: yearLevels.map(yearLevel => ({
                yearLevel: parseInt(yearLevel),
                guide: programGuides[yearLevel][0] // Take first guide (should only be one per year level)
            }))
        }
    }).filter(group => group.guides.length > 0)

    return (
        <AuthenticatedLayout
            header={
                <div className="flex items-center px-2 py-1">
                    <div className="flex items-center gap-2">
                        <div className="bg-purple-100 p-1.5 rounded-md">
                            <BookOpen className="w-4 h-4 text-purple-600" />
                        </div>
                        <div>
                            <h2 className="text-lg font-semibold text-gray-900">Year Level Curriculum Guides</h2>
                            <p className="text-xs text-gray-500 mt-0.5">Curriculum mapping for transferees & new enrollees</p>
                        </div>
                    </div>
                </div>
            }
        >
            <Head title="Year Level Curriculum Guides" />

            <div className="m-2 space-y-6">
                {/* Explanation Card */}
                <Card className="border-l-4 border-l-blue-500 bg-gradient-to-r from-blue-50 to-transparent">
                    <CardContent className="pt-6">
                        <div className="flex items-start gap-4">
                            <div className="bg-blue-100 p-3 rounded-lg">
                                <GraduationCap className="w-6 h-6 text-blue-600" />
                            </div>
                            <div className="flex-1">
                                <h3 className="text-lg font-semibold text-gray-900 mb-2">How Curriculum Guides Work</h3>
                                <div className="space-y-2 text-sm text-gray-700">
                                    <p>📘 <strong>Purpose:</strong> These guides help determine which curriculum to assign to transferees and first-time enrollees at different year levels.</p>
                                    <p>🎓 <strong>New 1st Year Students:</strong> Automatically use the program's <Badge variant="default" className="mx-1">Current Curriculum</Badge></p>
                                    <p>🔄 <strong>Continuing Students:</strong> Keep using their original curriculum (the one that was current when they started)</p>
                                    <p>📊 <strong>Transferees:</strong> Use this guide to assign the appropriate curriculum based on their entry year level</p>
                                    <div className="mt-3 p-3 bg-blue-100/50 rounded-lg">
                                        <p className="font-medium text-blue-900">💡 Example Scenario:</p>
                                        <p className="text-blue-800 mt-1">If you create a new curriculum for BSIT and set it as current:</p>
                                        <ul className="list-disc list-inside mt-2 space-y-1 text-blue-700">
                                            <li>New 1st year BSIT students → Use new (current) curriculum</li>
                                            <li>Current 2nd year students → Keep their old curriculum</li>
                                            <li>Transferee entering 2nd year → Follows this guide's 2nd year mapping</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </CardContent>
                </Card>

                {/* Filters */}
                <Card>
                    <CardContent className="pt-3 pb-3">
                        <div className="flex items-center justify-between mb-2">
                            <div className="flex items-center gap-3 ml-1">
                                <Filter className="w-4 h-4" />
                                <span className="text-sm font-medium">Filter Guides for {currentAcademicYear}</span>
                            </div>
                        </div>
                        <div className="flex items-end gap-3">
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-3 flex-1">
                                <div className="space-y-1">
                                    <Label className="text-xs font-medium text-gray-600">Program</Label>
                                    <Select
                                        value={localFilters.program_id || 'all'}
                                        onValueChange={(value) => handleFilterChange('program_id', value)}
                                    >
                                        <SelectTrigger className="h-8 text-sm">
                                            <SelectValue />
                                        </SelectTrigger>
                                        <SelectContent>
                                            <SelectItem value="all">All Programs</SelectItem>
                                            {programs.map(program => (
                                                <SelectItem key={program.id} value={program.id.toString()}>
                                                    {program.program_code} - {program.program_name}
                                                </SelectItem>
                                            ))}
                                        </SelectContent>
                                    </Select>
                                </div>

                                <div className="space-y-1">
                                    <Label className="text-xs font-medium text-gray-600">Education Level</Label>
                                    <Select
                                        value={localFilters.education_level || 'all'}
                                        onValueChange={(value) => handleFilterChange('education_level', value)}
                                    >
                                        <SelectTrigger className="h-8 text-sm">
                                            <SelectValue />
                                        </SelectTrigger>
                                        <SelectContent>
                                            <SelectItem value="all">All Levels</SelectItem>
                                            <SelectItem value="college">College</SelectItem>
                                            <SelectItem value="senior_high">Senior High School</SelectItem>
                                        </SelectContent>
                                    </Select>
                                </div>
                            </div>
                            <div className="flex items-end">
                                <Button asChild size="sm" className="bg-purple-600 hover:bg-purple-700 text-white h-8">
                                    <Link href={route('admin.year-level-curriculum-guides.create')}>
                                        <Plus className="w-3 h-3 mr-1" />
                                        Add Guide
                                    </Link>
                                </Button>
                            </div>
                        </div>
                    </CardContent>
                </Card>

                {/* Curriculum Distribution View */}
                <div className="space-y-6">
                    {groupedByProgram.length === 0 ? (
                        <Card>
                            <CardContent className="py-12">
                                <div className="text-center">
                                    <div className="bg-gradient-to-br from-purple-100 to-blue-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
                                        <BookOpen className="w-10 h-10 text-purple-600" />
                                    </div>
                                    <h3 className="text-xl font-semibold text-gray-900 mb-2">No Year Level Guides Found</h3>
                                    <p className="text-gray-600 mb-6 max-w-md mx-auto">
                                        No curriculum guides have been set up for {currentAcademicYear}. Create guides to help assign curriculums to transferees and new enrollees.
                                    </p>
                                    <Button asChild className="bg-purple-600 hover:bg-purple-700">
                                        <Link href={route('admin.year-level-curriculum-guides.create')}>
                                            <Plus className="w-4 h-4 mr-2" />
                                            Create First Guide
                                        </Link>
                                    </Button>
                                </div>
                            </CardContent>
                        </Card>
                    ) : (
                        groupedByProgram.map(({ program, curriculumGroups }) => (
                            <Card key={program.id} className="overflow-hidden">
                                <CardHeader className="bg-gradient-to-r from-purple-50 to-blue-50 border-b">
                                    <div className="flex items-center justify-between flex-wrap gap-4">
                                        <div>
                                            <CardTitle className="flex items-center gap-2 flex-wrap">
                                                <div className="bg-purple-100 p-2 rounded-lg">
                                                    <GraduationCap className="w-5 h-5 text-purple-600" />
                                                </div>
                                                <span>{program.program_name}</span>
                                                <Badge variant="secondary" className="font-mono">{program.program_code}</Badge>
                                                <Badge variant={program.education_level === 'college' ? 'default' : 'secondary'}>
                                                    {program.education_level === 'college' ? 'College' : 'Senior High School'}
                                                </Badge>
                                            </CardTitle>
                                            <CardDescription className="mt-2">
                                                📊 Curriculum Distribution • Academic Year: {currentAcademicYear}
                                            </CardDescription>
                                        </div>
                                    </div>
                                </CardHeader>
                                <CardContent className="pt-6">
                                    <div className="space-y-6">
                                        {curriculumGroups.map((group, index) => {
                                            const sortedYears = [...group.yearLevels].sort((a, b) => a - b)
                                            const isCurrentCurriculum = group.isCurrent
                                            
                                            return (
                                                <div key={group.curriculum.id} className={`relative border-2 rounded-xl p-6 transition-all ${
                                                    isCurrentCurriculum 
                                                        ? 'border-green-400 bg-gradient-to-r from-green-50 to-emerald-50' 
                                                        : 'border-gray-200 bg-gradient-to-r from-gray-50 to-slate-50'
                                                }`}>
                                                    {isCurrentCurriculum && (
                                                        <div className="absolute -top-3 left-6">
                                                            <Badge className="bg-green-600 text-white shadow-lg px-3 py-1">
                                                                ⭐ CURRENT CURRICULUM
                                                            </Badge>
                                                        </div>
                                                    )}
                                                    
                                                    <div className="flex items-start justify-between gap-4 mb-4">
                                                        <div className="flex items-start gap-4 flex-1">
                                                            <div className={`p-3 rounded-lg ${
                                                                isCurrentCurriculum ? 'bg-green-100' : 'bg-blue-100'
                                                            }`}>
                                                                <BookOpen className={`w-6 h-6 ${
                                                                    isCurrentCurriculum ? 'text-green-600' : 'text-blue-600'
                                                                }`} />
                                                            </div>
                                                            <div className="flex-1">
                                                                <h3 className="text-lg font-bold text-gray-900 mb-1">
                                                                    {group.curriculum.curriculum_name}
                                                                </h3>
                                                                <p className="text-sm text-gray-600 font-mono mb-3">
                                                                    {group.curriculum.curriculum_code}
                                                                </p>
                                                                <div className={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium ${
                                                                    isCurrentCurriculum 
                                                                        ? 'bg-green-100 text-green-800 border border-green-300'
                                                                        : 'bg-blue-100 text-blue-800 border border-blue-300'
                                                                }`}>
                                                                    {isCurrentCurriculum ? (
                                                                        <>
                                                                            <span className="text-lg">👥</span>
                                                                            <span>Used by NEW 1st Year Students</span>
                                                                        </>
                                                                    ) : (
                                                                        <>
                                                                            <span className="text-lg">📚</span>
                                                                            <span>Used by Continuing Students</span>
                                                                        </>
                                                                    )}
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    {/* Year Levels Using This Curriculum */}
                                                    <div className={`mt-4 p-4 rounded-lg border-2 ${
                                                        isCurrentCurriculum 
                                                            ? 'bg-white border-green-200' 
                                                            : 'bg-white border-gray-200'
                                                    }`}>
                                                        <div className="flex items-center gap-2 mb-3">
                                                            <span className="text-sm font-semibold text-gray-700">
                                                                📌 Year Levels Currently Using This Curriculum:
                                                            </span>
                                                        </div>
                                                        <div className="flex flex-wrap gap-2">
                                                            {sortedYears.map(yearLevel => {
                                                                const guide = guides[program.id]?.[yearLevel]?.[0]
                                                                return (
                                                                    <div key={yearLevel} className={`relative group`}>
                                                                        <div className={`flex items-center gap-2 px-4 py-2 rounded-lg border-2 transition-all ${
                                                                            isCurrentCurriculum
                                                                                ? 'bg-green-50 border-green-300 hover:bg-green-100'
                                                                                : 'bg-blue-50 border-blue-300 hover:bg-blue-100'
                                                                        }`}>
                                                                            <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold ${
                                                                                isCurrentCurriculum 
                                                                                    ? 'bg-green-600 text-white' 
                                                                                    : 'bg-blue-600 text-white'
                                                                            }`}>
                                                                                {yearLevel}
                                                                            </div>
                                                                            <span className="font-semibold text-gray-900">
                                                                                {getYearLevelLabel(program, yearLevel)}
                                                                            </span>
                                                                            <div className="flex gap-1 ml-2">
                                                                                <Button
                                                                                    variant="ghost"
                                                                                    size="icon"
                                                                                    className="h-6 w-6 opacity-0 group-hover:opacity-100 transition-opacity"
                                                                                    asChild
                                                                                >
                                                                                    <Link href={route('admin.year-level-curriculum-guides.edit', [program.id, yearLevel])}>
                                                                                        <Edit className="w-3 h-3" />
                                                                                    </Link>
                                                                                </Button>
                                                                                <Button
                                                                                    variant="ghost"
                                                                                    size="icon"
                                                                                    className="h-6 w-6 opacity-0 group-hover:opacity-100 transition-opacity text-red-600 hover:text-red-700 hover:bg-red-50"
                                                                                    onClick={() => {
                                                                                        if (confirm('Are you sure you want to delete this guide?')) {
                                                                                            router.delete(route('admin.year-level-curriculum-guides.destroy', [program.id, yearLevel]))
                                                                                        }
                                                                                    }}
                                                                                >
                                                                                    <Trash2 className="w-3 h-3" />
                                                                                </Button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                )
                                                            })}
                                                        </div>
                                                        
                                                        {isCurrentCurriculum && (
                                                            <div className="mt-3 p-3 bg-green-100 rounded-lg border border-green-300">
                                                                <p className="text-xs text-green-800 font-medium">
                                                                    💡 <strong>Note:</strong> This is the current curriculum. All NEW students entering 1st year will automatically be assigned to this curriculum. The year levels shown above are using this curriculum based on the guides you've set.
                                                                </p>
                                                            </div>
                                                        )}
                                                        
                                                        {!isCurrentCurriculum && (
                                                            <div className="mt-3 p-3 bg-blue-100 rounded-lg border border-blue-300">
                                                                <p className="text-xs text-blue-800 font-medium">
                                                                    📖 <strong>Previous Curriculum:</strong> Students who started in these year levels when this was the current curriculum continue using it. New 1st year students use the current curriculum instead.
                                                                </p>
                                                            </div>
                                                        )}
                                                    </div>
                                                </div>
                                            )
                                        })}
                                    </div>
                                </CardContent>
                            </Card>
                        ))
                    )}
                </div>
            </div>
        </AuthenticatedLayout>
    )
}